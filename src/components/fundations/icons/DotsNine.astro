---
const { variant, size, class: className, ...rest } = Astro.props
const xs = ['size-3']
const sm = ['size-4']
const base = ['size-5']
const md = ['size-6']
const lg = ['size-7']
const xl = ['size-8']
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="currentColor"
  stroke="currentColor"
  class:list={[
    'icon',
    size === 'xs' && xs,
    size === 'sm' && sm,
    size === 'base' && base,
    size === 'md' && md,
    size === 'lg' && lg,
    size === 'xl' && xl,
    className
  ]}
  {...rest}
>
  <path d="M4 18L20 18" stroke-width="2" stroke-linecap="round"></path>
  <path d="M4 12L20 12" stroke-width="2" stroke-linecap="round"></path>
  <path d="M4 6L20 6" stroke-width="2" stroke-linecap="round"></path>
</svg>
