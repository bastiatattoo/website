---
import Wrapper from "../fundations/containers/Wrapper.astro";
import RollingLink from "../fundations/elements/RollingLink.astro";
const { blok } = Astro.props;
---

<Wrapper variant="paddingless">
  <RollingLink
    href={blok.href?.story?.slug === "home"
      ? ""
      : blok.href?.story?.slug
        ? blok.href.story.slug
        : blok.href?.url
          ? blok.href.url
          : "#"}
    initialText={blok.text}
  />
</Wrapper>
