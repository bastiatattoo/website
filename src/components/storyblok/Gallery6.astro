---
import { storyblokEditable } from "@storyblok/astro";

// Assets
import { Image } from "astro:assets";
// Fundations
import Wrapper from "../fundations/containers/Wrapper.astro";
import Text from "../fundations/elements/Text.astro";

const { blok } = Astro.props;
---

<section {...storyblokEditable(blok)}>
  <Wrapper variant="standard" class="py-12 lg:py-24">
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:col-span-4 lg:grid-cols-[24rem_1fr_1fr]">
      <div class="flex flex-col gap-4 sm:col-span-2 lg:col-span-1">
        <div class="pb-12">
          <Text tag="h2" variant="displaySM" class="text-base-900 font-medium tracking-tight">
            {blok.title}
          </Text>
          <Text tag="p" variant="textLG" class="text-base-600 mt-4">
            {blok.intro}
          </Text>
        </div>
        {
          blok.images[0]?.filename && (
            <Image
              src={blok.images[0].filename}
              alt={blok.images[0]?.alt || " "}
              inferSize
              class="size-full rounded-xl object-cover"
            />
          )
        }
      </div>
      <div class="flex flex-col gap-4 sm:col-span-2 lg:col-span-1">
        {
          blok.images[1]?.filename && (
            <Image
              src={blok.images[1].filename}
              alt={blok.images[1]?.alt || " "}
              inferSize
              class="size-full rounded-xl object-cover"
            />
          )
        }
        {
          blok.images[2]?.filename && (
            <Image
              src={blok.images[2].filename}
              alt={blok.images[2]?.alt || " "}
              inferSize
              class="size-full rounded-xl object-cover"
            />
          )
        }
      </div>
      <div class="flex flex-col gap-4 sm:col-span-2 lg:col-span-1">
        {
          blok.images[3]?.filename && (
            <Image
              src={blok.images[3].filename}
              alt={blok.images[3]?.alt || " "}
              inferSize
              class="aspect-square size-full rounded-xl object-cover object-top"
            />
          )
        }
        {
          blok.images[4]?.filename && (
            <Image
              src={blok.images[4].filename}
              alt={blok.images[4]?.alt || " "}
              inferSize
              class="aspect-square size-full rounded-xl object-cover object-top"
            />
          )
        }
        {
          blok.images[5]?.filename && (
            <Image
              src={blok.images[5].filename}
              alt={blok.images[5]?.alt || " "}
              inferSize
              class="aspect-square size-full rounded-xl object-cover object-top"
            />
          )
        }
      </div>
    </div>
  </Wrapper>
</section>
