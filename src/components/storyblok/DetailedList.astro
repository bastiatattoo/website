---
// Assets
import { Image } from "astro:assets";
import { storyblokEditable } from "@storyblok/astro";
import RichTextRenderer from "storyblok-rich-text-astro-renderer/RichTextRenderer.astro";
import StoryblokComponent from "@storyblok/astro/StoryblokComponent.astro";

// Fundations
import Text from "../fundations/elements/Text.astro";
import Kicker from "../fundations/elements/Kicker.astro";
import Wrapper from "../fundations/containers/Wrapper.astro";

const { blok } = Astro.props;
---

<section {...storyblokEditable(blok)}>
  <Wrapper variant="standard" class="py-12 lg:py-24">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
      <div>
        <div class="bg-base-50 flex max-w-sm flex-col rounded-xl px-4 py-8 lg:sticky lg:top-24">
          <Kicker copy={blok.title} />
          <Text tag="h3" variant="textXLG" class="text-base-900 mt-12 font-medium text-balance">
            {blok.intro}
          </Text>
        </div>
      </div>
      <div class="divide-base-500 border-base-500 divide-y border-y lg:col-span-2">
        {
          blok.list.map((step) => (
            <div class="bg-base-100 grid grid-cols-1 gap-4 py-8 md:grid-cols-3 lg:sticky lg:top-0 lg:grid-cols-4">
              <div class="text-balance lg:col-span-2 lg:col-start-2">
                <Text
                  tag="h3"
                  variant="displaySM"
                  class="text-base-900 font-medium tracking-tight lg:text-balance">
                  {step.title}
                </Text>
                {step.description && (
                  <div class="text-base-600 prose textSM mt-2">
                    <RichTextRenderer
                      content={step.description}
                      resolver={(blok) => {
                        return {
                          component: StoryblokComponent,
                          props: { blok }
                        };
                      }}
                    />
                  </div>
                )}
              </div>
              {step.image?.filename && (
                <Image
                  src={step.image.filename}
                  alt={step.image.alt || " "}
                  inferSize
                  class="h-48 w-full rounded-xl object-cover"
                  layout="constrained"
                  quality="mid"
                />
              )}
            </div>
          ))
        }
      </div>
    </div>
  </Wrapper>
</section>
