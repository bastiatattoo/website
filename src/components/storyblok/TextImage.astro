---
// Assets
import { Image } from "astro:assets";
// Fundations
import Wrapper from "../fundations/containers/Wrapper.astro";
import Text from "../fundations/elements/Text.astro";
import { renderRichText } from "@storyblok/astro";

const { blok } = Astro.props;
const text = renderRichText(blok.text);
---

<section>
  <Wrapper variant="standard" class="py-12 lg:py-24">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-3">
      <div>
        <div class="max-w-sm lg:sticky lg:top-24">
          {
            blok.image.filename && (
              <Image
                src={blok.image.filename}
                alt={blok.image.alt}
                width={800}
                height={1080}
                loading="eager"
                decoding="async"
                class="aspect-square rounded-xl object-cover"
              />
            )
          }
          <Text tag="p" variant="textSM" class="text-base-600 mt-4 font-medium text-balance">
            {blok.imageDescription}
          </Text>
        </div>
      </div>
      <div class="lg:col-span-2">
        <Text tag="p" variant="displaySM" class="text-base-900 font-medium tracking-tight">
          {blok.title}
        </Text>
        <div class="textLG text-base-600 mt-8">
          <Fragment set:html={text} />
        </div>
      </div>
    </div>
  </Wrapper>
</section>
