---
// Assets
import { Image } from "astro:assets";
// Fundations
import Text from "../fundations/elements/Text.astro";
import Kicker from "../fundations/elements/Kicker.astro";
import Wrapper from "../fundations/containers/Wrapper.astro";
import RollingLink from "../fundations/elements/RollingLink.astro";

const { blok } = Astro.props;
const services = blok.list;
---

<section class="overflow-hidden">
  <Wrapper variant="wide" class="py-4">
    <div class="relative h-full min-h-screen overflow-hidden rounded-3xl">
      <div>
        {
          services.map((item, index) => (
            <Image
              id={`service-image-${index}`}
              src={item.image.filename}
              alt={item.image.alt}
              width={1440}
              height={1440}
              class="absolute inset-0 size-full object-cover object-center"
              style={`display: ${index === 0 ? "block" : "none"}`}
            />
          ))
        }
      </div>
      <div class="relative flex h-full flex-col lg:ml-auto lg:max-w-xl">
        <div class="bg-base-100 m-4 flex h-full flex-col justify-between rounded-2xl p-8">
          <div class="flex flex-col">
            <Kicker copy={blok.tagline} />
            <Text
              tag="p"
              variant="displaySM"
              class="text-base-900 mt-12 font-medium tracking-tight lg:text-balance">
              {blok.title}
            </Text>
            <div class="divide-base-200 border-base-200 mt-8 divide-y border-y">
              {
                services.map((item, index) => (
                  <button
                    class={`group text-base-900 w-full py-2 text-left transition-all ${index === 0 ? "" : "opacity-50"}`}
                    data-service-index={index}>
                    <Text
                      tag="p"
                      variant="textLG"
                      class="font-medium transition-all duration-500 ease-in-out group-focus:translate-x-4">
                      {item.title}
                    </Text>
                  </button>
                ))
              }
            </div>
            <Text
              tag="p"
              variant="textBase"
              class="text-base-600 mt-8 text-balance"
              id="active-description">
              {services[0].description}
            </Text>
          </div>
          {
            blok.linkUrl.story?.full_slug && (
              <RollingLink
                href={blok.linkUrl.story.full_slug}
                initialText={blok.linkInitialText}
                class="mt-8 self-end"
              />
            )
          }
        </div>
      </div>
    </div>
  </Wrapper>
</section>
<script define:vars={{ services }}>
  window.services = services;
  const buttons = document.querySelectorAll("[data-service-index]");
  const images = document.querySelectorAll("[id^='service-image-']");
  const descriptionEl = document.getElementById("active-description");
  buttons.forEach((button, index) => {
    button.addEventListener("click", () => {
      // Update active tab
      buttons.forEach((btn, i) => {
        if (i === index) {
          btn.classList.remove("opacity-50");
        } else {
          btn.classList.add("opacity-50");
        }
      });
      // Update visible image
      images.forEach((img, i) => {
        img.style.display = i === index ? "block" : "none";
      });
      // Update description
      descriptionEl.textContent = window.services[index].description;
    });
  });
</script>
