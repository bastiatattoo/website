---
// Assets
import { Image } from "astro:assets";
// Fundations

const { post } = Astro.props;
---

<article class="group keen-slider__slide relative flex flex-col">
  <Image
    src={post.image.filename}
    alt={post.image.alt || " "}
    inferSize
    layout="constrained"
    class="h-full max-h-[80vh] w-full rounded-xl object-cover object-center"
  />
</article>
